# Copy this file to ".env"  (cp env.example .env)  and fill in values.

# ----- Server -----
PORT=4000
# Comma-separated list of allowed frontend origins (CORS). Use * to allow all.
CORS_ORIGIN=http://localhost:5173

# ----- Playwright -----
# true = no visible window (required on Render). false = watch it work locally.
HEADLESS=true

# ----- Grok (xAI) LLM  [OPTIONAL] -----
# Get a key at https://console.x.ai . If left blank, the agent uses local
# heuristics only and never crashes.
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-2-latest

# ----- Qdrant Vector DB  [OPTIONAL] -----
# Create a free cluster at https://cloud.qdrant.io . If blank, logging falls
# back to in-memory only and the app keeps working.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=agent_logs
